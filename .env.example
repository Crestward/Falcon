# ----------------------------------------------------------------------------
# FALCON environment template. Copy to `.env` and fill in.
# ----------------------------------------------------------------------------

# --- LLM backend selection -----------------------------------------------
# Agents:  `ollama` (local) | `anthropic` (direct API, recommended for dev) |
#          `bedrock` (AWS) | `vertex` (GCP, UK demo)
LLM_BACKEND=anthropic
# Judge: `anthropic` | `bedrock` (default, cross-vendor neutral) | `vertex`. Never ollama.
JUDGE_BACKEND=anthropic

# --- Ollama (local backend) ----------------------------------------------
OLLAMA_HOST=http://host.docker.internal:11434
# Set to -1 to keep models pinned in VRAM during long HITL pauses.
# See plan section 2.2 (HITL cold-load gotcha).
OLLAMA_KEEP_ALIVE=-1

# --- Anthropic API (direct, recommended for dev) -------------------------
# Cheapest & fastest dev path. Prompt caching is enabled automatically
# in agents.llm_utils for this backend — ~90% off the input bill on the
# static system block (schema + example + role prompt).
ANTHROPIC_API_KEY=
# All five agent roles default to Haiku 4.5. Override per role to split later.
ANTHROPIC_MODEL_TRIAGE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_ACCOUNT_HISTORIAN=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_NETWORK_MAPPER=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_PATTERN_HUNTER=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_CASE_WRITER=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_JUDGE=claude-sonnet-4-6

# --- Bedrock (cloud backend) ---------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_DEFAULT=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MODEL_JUDGE=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# --- Vertex AI (GCP backend) ---------------------------------------------
# Auth uses Application Default Credentials, NOT keys in this file.
# Locally:  gcloud auth application-default login
# In prod:  workload identity (GKE/Cloud Run service account)
# europe-west2 = London region — needed for UK bank data residency.
GCP_PROJECT_ID=
GCP_REGION=europe-west2
VERTEX_MODEL_DEFAULT=gemini-2.5-flash
VERTEX_MODEL_JUDGE=gemini-2.5-pro

# --- Postgres ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=falcon
POSTGRES_PASSWORD=falcon_dev_only
POSTGRES_DB=falcon
DATABASE_URL=postgresql+psycopg://falcon:falcon_dev_only@localhost:5432/falcon

# --- Observability -------------------------------------------------------
OTEL_SERVICE_NAME=falcon
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true

# LangSmith (free tier is enough for the build)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=falcon-dev

# --- MCP server ports ----------------------------------------------------
MCP_TRANSACTION_STORE_PORT=8001
MCP_NETWORK_GRAPH_PORT=8002
MCP_WATCHLIST_PORT=8003
MCP_CASE_MANAGEMENT_PORT=8004

# --- API -----------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
